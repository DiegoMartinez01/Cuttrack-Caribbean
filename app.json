{
  "expo": {
    "name": "CUTTRACK Caribbean",
    "slug": "cuttrack-caribbean",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cuttrack",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A15"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cuttrack.caribbean",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSPhotoLibraryUsageDescription": "Permite a CUTTRACK acceder a tu galería para subir fotos de perfil",
        "NSCameraUsageDescription": "Permite a CUTTRACK acceder a tu cámara para tomar fotos",
        "NSMicrophoneUsageDescription": "Permite a CUTTRACK acceder al micrófono para funciones de voz"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A15"
      },
      "package": "com.cuttrack.caribbean",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "shrinkResources": true
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B35",
          "sounds": ["./assets/sounds/notification.wav"]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite a CUTTRACK acceder a tu galería para subir fotos de perfil",
          "cameraPermission": "Permite a CUTTRACK acceder a tu cámara para tomar fotos"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permite a CUTTRACK acceder a tus fotos",
          "savePhotosPermission": "Permite a CUTTRACK guardar imágenes en tu galería",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f42b6214-2c24-4ad3-bca8-eb7b8d63a1b5"
      }
    }
  }
}